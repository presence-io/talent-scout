.# .gitignore for talent-scout

# 环境与密钥（不要将凭证提交）
.env
.env.*
.env.local
.envrc

# Python: byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
venv.bak/

# Packaging / build
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test / coverage / type check caches
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/
.mypy_cache/
.pytype/

# Jupyter
.ipynb_checkpoints/

# Logs
logs/
*.log

# IDEs / editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# macOS / Windows
.DS_Store
Thumbs.db

# Node
node_modules/
dist/

# Project-specific generated results
output/

# Runtime data
workspace-data/
user-data/

# API 缓存
cache/

# v1 Python 代码备份
legacy/

# Misc
*.sqlite3
*.db
*.bak

# Agent temp files
.agent/

# End of file
