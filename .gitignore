# .gitignore for talent-scout

# 环境与密钥（不要将凭证提交）
.env
.env.*
.env.local
.envrc

# Packaging / build
build/
dist/

# Test / coverage / type check caches
coverage/

# Logs
logs/
*.log

# IDEs / editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# macOS / Windows
.DS_Store
Thumbs.db

# Node
node_modules/
dist/

# Runtime data (keep workspace-data/output/ tracked for pipeline results)
workspace-data/input/
workspace-data/cache/
user-data/

# API 缓存
cache/

# Misc
*.sqlite3
*.db
*.bak
.playwright-mcp/
tsconfig.tsbuildinfo

# Astro
.astro/

# Agent temp files
.agent/

# End of file
