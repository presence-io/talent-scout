---
import '@/styles/global.css';
import { loadDashboardCapabilities } from '@/lib/dashboard-config';

interface Props {
  title: string;
}

const { title } = Astro.props;
const dashboardCapabilities = loadDashboardCapabilities();
---

<!doctype html>
<html lang="en" data-theme="corporate">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Talent Scout</title>
  </head>
  <body class="bg-base-200 min-h-screen">
    <div class="navbar bg-base-100 shadow-sm">
      <div class="flex-1">
        <a class="btn btn-ghost text-xl" href="/">Talent Scout</a>
      </div>
      <div class="flex-none">
        <ul class="menu menu-horizontal px-1">
          <li><a href="/">Candidates</a></li>
          <li><a href="/stats">Stats</a></li>
          {
            dashboardCapabilities.showOpenClawFeatures && (
              <li>
                <a href="/cron">Cron</a>
              </li>
            )
          }
        </ul>
      </div>
    </div>
    <main class="container mx-auto p-4">
      {
        dashboardCapabilities.readOnly && (
          <div class="alert alert-warning mb-4">
            <span>
              This dashboard was opened from a workspace zip and is running in read-only mode.
              Editing actions and OpenClaw features are hidden.
            </span>
          </div>
        )
      }
      <slot />
    </main>
  </body>
</html>
