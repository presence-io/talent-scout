---
import Base from '../layouts/Base.astro';
import { loadDashboardCapabilities, loadDashboardTalentConfig } from '@/lib/dashboard-config';
import { listRunHistory } from '@/lib/file';
import type { RunHistoryEntry } from '@/lib/file';

let cronJobs: { name: string; schedule: string; command: string; description?: string }[] = [];
let configError: string | null = null;
let runHistory: RunHistoryEntry[] = [];
const dashboardCapabilities = loadDashboardCapabilities();

if (dashboardCapabilities.showOpenClawFeatures) {
  try {
    const config = await loadDashboardTalentConfig();
    cronJobs = config.openclaw.cron;
  } catch (err) {
    configError = err instanceof Error ? err.message : String(err);
  }

  try {
    runHistory = await listRunHistory(process.cwd());
  } catch {
    // ignore
  }
}
---

<Base title="Cron Jobs">
  <h1 class="mb-4 text-2xl font-bold">Cron Jobs</h1>

  {
    !dashboardCapabilities.showOpenClawFeatures && (
      <div class="alert alert-info">
        <span>
          OpenClaw cron controls are hidden while the dashboard is reading a workspace zip. Extract
          the workspace locally and start the dashboard against that directory to re-enable them.
        </span>
      </div>
    )
  }

  {
    configError && dashboardCapabilities.showOpenClawFeatures && (
      <div class="alert alert-warning mb-4">
        <span>Could not load config: {configError}</span>
      </div>
    )
  }

  {
    cronJobs.length === 0 && !configError && dashboardCapabilities.showOpenClawFeatures && (
      <div class="alert alert-info mb-4">
        <span>
          No cron jobs configured. Add entries to <code>openclaw.cron</code> in talents.yaml.
        </span>
      </div>
    )
  }

  {
    cronJobs.length > 0 && dashboardCapabilities.showOpenClawFeatures && (
      <div class="mb-8 overflow-x-auto">
        <table class="table-zebra table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Schedule</th>
              <th>Command</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            {cronJobs.map((job) => (
              <tr>
                <td class="font-semibold">{job.name}</td>
                <td>
                  <code>{job.schedule}</code>
                </td>
                <td>
                  <code>{job.command}</code>
                </td>
                <td>{job.description ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }

  {
    dashboardCapabilities.showOpenClawFeatures && (
      <h2 class="mb-3 text-xl font-bold">Recent Runs</h2>
    )
  }

  {
    dashboardCapabilities.showOpenClawFeatures && (
      <div class="mb-4 flex items-center gap-4">
        <button class="btn btn-primary btn-sm" disabled title="Trigger via OpenClaw scheduler">
          Run Now
        </button>
        <span class="text-base-content/60 text-sm">
          Actual execution is handled by the OpenClaw scheduler.
        </span>
      </div>
    )
  }

  {
    runHistory.length === 0 && dashboardCapabilities.showOpenClawFeatures && (
      <div class="alert alert-info">
        <span>
          No run history found. Runs will appear in <code>output/evaluated/</code>.
        </span>
      </div>
    )
  }

  {
    runHistory.length > 0 && dashboardCapabilities.showOpenClawFeatures && (
      <div class="overflow-x-auto">
        <table class="table-zebra table">
          <thead>
            <tr>
              <th>Timestamp</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {runHistory.map((run) => (
              <tr>
                <td>
                  <code>{run.timestamp}</code>
                </td>
                <td>
                  {run.isLatest ? (
                    <span class="badge badge-success">Latest</span>
                  ) : (
                    <span class="badge badge-ghost">Completed</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</Base>
