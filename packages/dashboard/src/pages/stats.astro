---
import Base from '../layouts/Base.astro';
import { loadShortlist } from '@talent-scout/ai-evaluator';
import { resolveOutputDir } from '@/lib/file';
import {
  computeActionDistribution,
  computeTierDistribution,
  computeCityDistribution,
  computeConfidenceBuckets,
  computeSignalTypeDistribution,
} from '@/lib/stats';
import { formatAction, formatTier } from '@/lib/format';

const base = process.cwd();
const outputDir = resolveOutputDir(base);
const entries = await loadShortlist(outputDir).catch(() => []);

const actionDist = computeActionDistribution(entries);
const tierDist = computeTierDistribution(entries);
const cityDist = computeCityDistribution(entries);
const confidenceBuckets = computeConfidenceBuckets(entries);
const signalDist = computeSignalTypeDistribution(entries);
---

<Base title="Statistics">
  <h1 class="mb-4 text-2xl font-bold">Statistics</h1>

  <div class="stats mb-6 w-full shadow">
    <div class="stat">
      <div class="stat-title">Total Candidates</div>
      <div class="stat-value">{entries.length}</div>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
    <!-- Action Distribution -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h3 class="card-title">Recommended Actions</h3>
        {
          actionDist.map((d) => (
            <div class="mb-1 flex items-center gap-2">
              <span class="w-24 text-sm">{formatAction(d.label)}</span>
              <progress class="progress progress-primary flex-1" value={d.percentage} max="100" />
              <span class="w-16 text-right text-sm">
                {d.count} ({d.percentage}%)
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Tier Distribution -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h3 class="card-title">AI Depth Tiers</h3>
        {
          tierDist.map((d) => (
            <div class="mb-1 flex items-center gap-2">
              <span class="w-24 text-sm">{formatTier(d.label)}</span>
              <progress class="progress progress-secondary flex-1" value={d.percentage} max="100" />
              <span class="w-16 text-right text-sm">
                {d.count} ({d.percentage}%)
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- City Distribution -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h3 class="card-title">Top Cities</h3>
        {
          cityDist.map((d) => (
            <div class="mb-1 flex items-center gap-2">
              <span class="w-24 truncate text-sm" title={d.label}>
                {d.label}
              </span>
              <progress class="progress progress-accent flex-1" value={d.percentage} max="100" />
              <span class="w-16 text-right text-sm">
                {d.count} ({d.percentage}%)
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- China Confidence Buckets -->
    <div class="card bg-base-100 shadow">
      <div class="card-body">
        <h3 class="card-title">China Confidence</h3>
        {
          confidenceBuckets.map((d) => (
            <div class="mb-1 flex items-center gap-2">
              <span class="w-24 text-sm">{d.label}</span>
              <progress class="progress progress-info flex-1" value={d.percentage} max="100" />
              <span class="w-16 text-right text-sm">
                {d.count} ({d.percentage}%)
              </span>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Signal Type Distribution -->
    {
      signalDist.length > 0 && (
        <div class="card bg-base-100 shadow">
          <div class="card-body">
            <h3 class="card-title">Signal Sources</h3>
            {signalDist.map((d) => (
              <div class="mb-1 flex items-center gap-2">
                <span class="w-36 truncate text-sm" title={d.label}>
                  {d.label}
                </span>
                <progress class="progress progress-warning flex-1" value={d.percentage} max="100" />
                <span class="w-16 text-right text-sm">
                  {d.count} ({d.percentage}%)
                </span>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</Base>
