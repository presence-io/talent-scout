  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node ./bin/talent-scout-dashboard.mjs",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@talent-scout/ai-evaluator": "workspace:*",
    "@talent-scout/shared": "workspace:*",
    "astro": "^5.6.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@astrojs/node": "^9.1.3",
    "@tailwindcss/vite": "^4.1.1",
    "@types/node": "^25.5.0",
    "daisyui": "^5.0.14",
    "tailwindcss": "^4.1.1",
    "tsx": "^4.19.3"
  }
}
