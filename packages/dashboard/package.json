{
  "name": "@talent-scout/dashboard",
  "version": "0.1.0",
  "homepage": "https://github.com/presence-io/talent-scout",
  "license": "MIT",
  "type": "module",
  "main": "./dist/server/entry.mjs",
  "bin": "./bin/talent-scout-dashboard.mjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist/",
    "bin/",
    "dashboard.config.mjs"
  ],
  "publishConfig": {
