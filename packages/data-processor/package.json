    "process": "tsx src/cli.ts",
    "validate:identity": "tsx src/validate-identity.ts"
  },
  "dependencies": {
    "@talent-scout/shared": "workspace:*",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.19.3"
  }
}
