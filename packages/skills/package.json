{
  "name": "@talent-scout/skills",
  "version": "0.1.0",
  "homepage": "https://github.com/presence-io/talent-scout",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "SKILL.md",
    "talents.yaml",
    "references",
    "scripts"
  ],
  "scripts": {
    "build": "tsc --build",
    "skill": "tsx src/index.ts"
  },
  "dependencies": {
    "@talent-scout/ai-evaluator": "workspace:*",
    "@talent-scout/data-collector": "workspace:*",
    "@talent-scout/data-processor": "workspace:*",
    "@talent-scout/shared": "workspace:*",
    "adm-zip": "^0.5.16"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.5.0",
    "tsx": "^4.19.3"
  }
}
